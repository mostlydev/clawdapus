{
  "name": "clawdash-ui",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./tailwind.css -o ./static/app.css --minify",
    "build:alpine": "cp ./node_modules/alpinejs/dist/cdn.min.js ./static/alpine.js",
    "build": "npm run build:css && npm run build:alpine"
  },
  "devDependencies": {
    "alpinejs": "^3.14.9",
    "tailwindcss": "^3.4.17"
  }
}
